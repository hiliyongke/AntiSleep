{
  "$schema": "https://raw.githubusercontent.com/nichuanfang/resources/main/tauri-2.json",
  "productName": "AntiSleep",
  "version": "0.1.0",
  "identifier": "com.antisleep.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AntiSleep",
        "visible": false,
        "backgroundColor": "#1C1C1E"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https://asset.localhost; font-src 'self' data:; media-src 'self' asset: https://asset.localhost; connect-src 'self' https://localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
